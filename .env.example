# Public site URL — used for canonical links, sitemap, and JSON-LD.
SITE_URL="https://virtuousafricasafaris.com"

# ---------------------------------------------------------------------------
# PHASE 2 — production wiring for the /api/* endpoint stubs.
# None of these are read by the v1 stubs; they document what you'll need.
# ---------------------------------------------------------------------------

# Transactional email (Resend) — used by /api/inquiry and /api/newsletter.
RESEND_API_KEY=""
OWNER_NOTIFICATION_EMAIL="reservations@virtuousafricasafaris.com"
RESEND_AUDIENCE_ID=""

# WhatsApp Cloud API — used by /api/inquiry and /api/chat/start.
WHATSAPP_BUSINESS_NUMBER=""
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""

# Database (Supabase / Neon) — used to persist inquiries + chat sessions.
DATABASE_URL=""
