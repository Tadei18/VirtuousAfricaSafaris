---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/ui/PageHeader.astro";
import FaqAccordion from "@/components/ui/FaqAccordion.astro";
import MultiStepInquiry from "@/components/react/MultiStepInquiry.tsx";
import { contactSeo } from "@/data/seo";
import { faqPageJsonLd } from "@/lib/jsonld";
import { generalFaqs } from "@/data/faqs";
import { contact, phones, whatsappUrl, siteTagline } from "@/lib/constants";
import { Phone, Mail, MapPin, Clock, MessageCircle } from "lucide-react";

const details: Array<{
  icon: typeof Phone;
  label: string;
  value?: string;
  href?: string;
  phones?: typeof phones;
}> = [
  { icon: Phone, label: "Call or WhatsApp", phones },
  { icon: Mail, label: "Email", value: contact.email, href: `mailto:${contact.email}` },
  { icon: MapPin, label: "Office", value: contact.address },
  { icon: Clock, label: "Hours", value: `${contact.hours} · ${contact.timezone}` },
];
---

<BaseLayout seo={contactSeo} jsonLd={[faqPageJsonLd(generalFaqs)]}>
  <PageHeader
    eyebrow="Plan your safari"
    title="Tell us the trip. We'll build the plan."
    intro="Answer a few quick questions and a real planner sends back a tailored itinerary and quote within 24 hours. No bots, no obligation."
  />

  <section class="bg-[#faf5ec] py-16 lg:py-20">
    <div class="mx-auto grid max-w-[1400px] gap-12 px-5 lg:grid-cols-[1.4fr_0.9fr] lg:gap-16 lg:px-10">
      <div data-reveal>
        <MultiStepInquiry client:load />
      </div>

      <aside class="space-y-6" data-reveal style="--reveal-delay:100ms">
        <div class="rounded-[1.5rem] border border-[color:var(--color-line-ink)] bg-[#fffdf9] p-6">
          <h2 class="font-display text-xl font-bold text-[color:var(--color-charcoal)]">Rather talk it through?</h2>
          <p class="mt-1 text-sm text-[color:var(--color-charcoal-soft)]">{siteTagline}</p>
          <ul class="mt-5 space-y-4">
            {details.map((d) => (
              <li class="flex items-start gap-3.5">
                <span class="inline-flex size-10 shrink-0 items-center justify-center rounded-xl bg-[#3f200f]/12 text-[#3f200f]">
                  <d.icon className="size-5" />
                </span>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wider text-[color:var(--color-charcoal-soft)]">{d.label}</p>
                  {d.phones ? (
                    <div class="flex flex-col gap-0.5">
                      {d.phones.map((p) => (
                        <a href={`tel:${p.tel}`} class="text-sm font-medium text-[color:var(--color-charcoal)] transition-colors hover:text-[#3f200f]">{p.display}</a>
                      ))}
                    </div>
                  ) : d.href ? (
                    <a href={d.href} class="text-sm font-medium text-[color:var(--color-charcoal)] transition-colors hover:text-[#3f200f]">{d.value}</a>
                  ) : (
                    <p class="text-sm font-medium text-[color:var(--color-charcoal)]">{d.value}</p>
                  )}
                </div>
              </li>
            ))}
          </ul>
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer"
            class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-full bg-[#3f200f] px-5 py-3 text-sm font-bold text-white transition-colors hover:bg-[#5c3b26]">
            <MessageCircle className="size-4" /> Chat on WhatsApp
          </a>
          <p class="mt-3 text-center text-[11px] text-[color:var(--color-charcoal-soft)]">
            Office address to be confirmed before launch.
          </p>
        </div>
      </aside>
    </div>

    <!-- General FAQ -->
    <div class="mx-auto mt-16 max-w-3xl px-5 lg:px-10" data-reveal>
      <h2 class="display-3 text-center text-[color:var(--color-charcoal)]">Questions, answered</h2>
      <div class="mt-8">
        <FaqAccordion faqs={generalFaqs} idPrefix="contact-faq" />
      </div>
    </div>
  </section>
</BaseLayout>
