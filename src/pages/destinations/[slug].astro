---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BestTimeChart from "@/components/destinations/BestTimeChart.astro";
import TourCard from "@/components/tours/TourCard.astro";
import Icon from "@/components/ui/Icon.astro";
import { destinations } from "@/data/destinations";
import { tours } from "@/data/tours";
import { destinationSeo } from "@/data/seo";
import { touristDestinationJsonLd } from "@/lib/jsonld";
import { ArrowLeft, Calendar, Maximize, Check, ArrowRight } from "lucide-react";

export function getStaticPaths() {
  return destinations.map((destination) => ({
    params: { slug: destination.slug },
    props: { destination },
  }));
}

const { destination: d } = Astro.props;
const relatedTours = tours.filter((t) => t.destinations.includes(d.slug)).slice(0, 3);
const seo = destinationSeo(d);
const jsonLd = [touristDestinationJsonLd(d)];
---

<BaseLayout seo={seo} jsonLd={jsonLd} transparentHeader>
  <!-- Hero -->
  <section class="relative isolate flex min-h-[70svh] flex-col justify-end overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <img src={d.heroImage} alt={d.name} fetchpriority="high" class="size-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-t from-[#0c0e12] via-[#0c0e12]/50 to-[#0c0e12]/40"></div>
    </div>
    <div class="mx-auto w-full max-w-[1400px] px-5 pb-14 pt-32 lg:px-10 lg:pb-16">
      <a href="/destinations" class="inline-flex items-center gap-2 text-sm font-semibold text-[color:var(--color-fog)] transition-colors hover:text-[#ff6a1a]">
        <ArrowLeft class="size-4" /> All destinations
      </a>
      <h1 class="display-1 mt-5 text-[color:var(--color-bone)]">{d.name}</h1>
      <p class="mt-3 font-display text-xl font-semibold text-[#ffb056]">{d.oneLineDraw}</p>
      <div class="mt-6 flex flex-wrap gap-2">
        {d.signatureWildlife.map((w) => (
          <span class="rounded-full border border-white/20 bg-black/30 px-3 py-1 text-xs font-semibold text-white backdrop-blur">{w}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[#0c0e12] py-16 lg:py-20">
    <div class="mx-auto max-w-[1400px] px-5 lg:px-10">
      <div class="grid gap-12 lg:grid-cols-[1.2fr_0.8fr] lg:gap-16">
        <!-- Why go -->
        <div data-reveal>
          <p class="text-xl leading-relaxed text-[color:var(--color-bone)]/90">{d.shortDescription}</p>
          <h2 class="display-3 mt-12 text-[color:var(--color-bone)]">Why go</h2>
          <div class="mt-5 space-y-4 text-lg leading-relaxed text-[color:var(--color-fog)]">
            {d.whyGo.map((p) => <p>{p}</p>)}
          </div>
        </div>

        <!-- Facts card -->
        <aside class="space-y-6" data-reveal style="--reveal-delay:100ms">
          <div class="rounded-[1.5rem] border border-[color:var(--color-line)] bg-[#12151b] p-6">
            <h3 class="font-display text-lg font-bold text-[color:var(--color-bone)]">At a glance</h3>
            <dl class="mt-4 space-y-3 text-sm">
              {d.sizeKm2 > 0 && (
                <div class="flex items-center justify-between border-b border-[color:var(--color-line)] pb-3">
                  <dt class="inline-flex items-center gap-2 text-[color:var(--color-fog)]"><Maximize class="size-4 text-[#ff6a1a]" /> Size</dt>
                  <dd class="font-semibold text-[color:var(--color-bone)]">{d.sizeKm2.toLocaleString()} km²</dd>
                </div>
              )}
              <div class="flex items-start justify-between gap-4">
                <dt class="inline-flex items-center gap-2 text-[color:var(--color-fog)]"><Calendar class="size-4 text-[#ff6a1a]" /> Best months</dt>
                <dd class="text-right font-semibold text-[color:var(--color-bone)]">{d.bestMonths.join(", ")}</dd>
              </div>
            </dl>
          </div>

          <div>
            <h3 class="font-display text-lg font-bold text-[color:var(--color-bone)]">Best time to visit</h3>
            <p class="mt-1 text-sm text-[color:var(--color-fog)]">Wildlife-viewing quality by month.</p>
            <div class="mt-4">
              <BestTimeChart scores={d.monthlyScore} />
            </div>
          </div>
        </aside>
      </div>

      <!-- Species -->
      <div class="mt-16" data-reveal>
        <h2 class="display-3 text-[color:var(--color-bone)]">What you'll see</h2>
        <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {d.species.map((s) => (
            <div class="flex gap-4 rounded-2xl border border-[color:var(--color-line)] bg-[#12151b] p-5 transition-colors hover:border-[#ff6a1a]/30">
              <span class="inline-flex size-11 shrink-0 items-center justify-center rounded-xl bg-[#ff6a1a]/12 text-[#ff6a1a]">
                <Icon name={s.icon} class="size-5" />
              </span>
              <div>
                <h3 class="font-display text-base font-bold text-[color:var(--color-bone)]">{s.name}</h3>
                <p class="mt-1 text-sm leading-relaxed text-[color:var(--color-fog)]">{s.note}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Related tours -->
  {relatedTours.length > 0 && (
    <section class="border-t border-[color:var(--color-line)] bg-[#0c0e12] py-16 lg:py-20">
      <div class="mx-auto max-w-[1400px] px-5 lg:px-10">
        <div class="flex items-end justify-between gap-6">
          <h2 class="display-3 text-[color:var(--color-bone)]">Safaris that visit {d.name}</h2>
          <a href="/safaris" class="group hidden shrink-0 items-center gap-2 text-sm font-bold text-[#ff6a1a] sm:inline-flex">
            All safaris <ArrowRight class="size-4 transition-transform group-hover:translate-x-1" />
          </a>
        </div>
        <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {relatedTours.map((t) => <TourCard tour={t} />)}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
