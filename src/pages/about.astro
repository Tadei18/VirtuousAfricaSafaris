---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/ui/PageHeader.astro";
import { guides } from "@/data/guides";
import { aboutSeo } from "@/data/seo";
import { Languages, Award, Leaf, Users, HandHeart, Globe2 } from "lucide-react";

const values = [
  { icon: HandHeart, title: "Kenyan-owned", body: "Decisions made in Nairobi, not a call centre abroad. Profit stays in the country that grows the wild." },
  { icon: Leaf, title: "Conservation-first", body: "We route through community conservancies so your trip becomes a direct reason to protect wildlife." },
  { icon: Users, title: "Local guides, always", body: "Every trip is led by a specialist who grew up reading these plains — never a rotating stranger." },
  { icon: Globe2, title: "Honest by default", body: "Clear pricing, realistic expectations, and advice that sometimes means telling you to travel a different month." },
];

const initials = (name: string) =>
  name.split(" ").map((n) => n[0]).slice(0, 2).join("");
---

<BaseLayout seo={aboutSeo}>
  <PageHeader
    eyebrow="About us"
    title="A small outfit that takes the wild seriously."
    intro="Virtuous Africa Safaris is a Kenyan-owned team of guides, planners and conservation partners. We build private journeys the way we'd plan our own — honestly, and around the wildlife."
    image="/images/visual-essay/wild-dogs-laikipia.webp"
    imageAlt="A pack of wild dogs moving through Laikipia scrubland"
  />

  <!-- Story -->
  <section class="bg-[#faf5ec] py-16 lg:py-24">
    <div class="mx-auto grid max-w-[1400px] gap-12 px-5 lg:grid-cols-[1fr_1fr] lg:gap-20 lg:px-10">
      <div data-reveal>
        <p class="eyebrow text-[#96690f]">Our story</p>
        <h2 class="display-2 mt-4 text-[color:var(--color-charcoal)]">Built by guides, for travellers who want the real thing.</h2>
      </div>
      <div class="space-y-4 text-lg leading-relaxed text-[color:var(--color-charcoal-soft)]" data-reveal style="--reveal-delay:100ms">
        <p>We started the way most good safari companies do — a handful of guides who were tired of watching visitors get moved through Kenya on a conveyor belt of minibuses and rushed sightings.</p>
        <p>So we built the opposite. Private vehicles. Local specialists who stay with you. Routes sequenced so you spend your days in the parks, not on the roads. And a deliberate bias toward the conservancies, where vehicle numbers are limited and a real share of your money reaches the communities protecting the land.</p>
        <p>We're not the biggest operator in Nairobi, and we don't want to be. We'd rather run fewer trips and get every one of them right.</p>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="relative overflow-hidden bg-[color:var(--color-paper)] text-[color:var(--color-charcoal)]">
    <div class="mx-auto max-w-[1400px] px-5 py-16 lg:px-10 lg:py-24">
      <div class="max-w-2xl" data-reveal>
        <p class="eyebrow text-[#96690f]">What we stand for</p>
        <h2 class="display-2 mt-4">Four things we won't compromise on.</h2>
      </div>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {values.map((v, i) => (
          <div class="rounded-2xl border border-[color:var(--color-line-ink)] bg-white/60 p-6" data-reveal style={`--reveal-delay:${(i % 4) * 70}ms`}>
            <span class="inline-flex size-12 items-center justify-center rounded-xl bg-[#3f200f]/12 text-[#96690f]">
              <v.icon className="size-6" />
            </span>
            <h3 class="mt-5 font-display text-lg font-bold">{v.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-[color:var(--color-charcoal-soft)]">{v.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Guides -->
  <section class="bg-[#faf5ec] py-16 lg:py-24">
    <div class="mx-auto max-w-[1400px] px-5 lg:px-10">
      <div class="max-w-2xl" data-reveal>
        <p class="eyebrow text-[#96690f]">The people</p>
        <h2 class="display-2 mt-4 text-[color:var(--color-charcoal)]">Guides who read the bush.</h2>
        <p class="mt-4 text-lg text-[color:var(--color-charcoal-soft)]">The single biggest factor in a great safari is who's driving. Meet a few of ours.</p>
      </div>
      <div class="mt-12 grid gap-6 sm:grid-cols-2">
        {guides.map((g, i) => (
          <div class="flex gap-5 rounded-[1.5rem] border border-[color:var(--color-line-ink)] bg-[#fffdf9] p-6 transition-colors hover:border-[#3f200f]/30" data-reveal style={`--reveal-delay:${(i % 2) * 90}ms`}>
            <div class="flex size-16 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-[#3f200f] to-[#96690f] font-display text-xl font-extrabold text-white" aria-hidden="true">
              {initials(g.name)}
            </div>
            <div class="min-w-0">
              <h3 class="font-display text-lg font-bold text-[color:var(--color-charcoal)]">{g.name}</h3>
              <p class="text-sm font-semibold text-[#96690f]">{g.specialty}</p>
              <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1 text-xs text-[color:var(--color-charcoal-soft)]">
                <span class="inline-flex items-center gap-1.5"><Award className="size-3.5 text-[#3f200f]" /> {g.yearsInField} yrs in the field</span>
                <span class="inline-flex items-center gap-1.5"><Languages className="size-3.5 text-[#3f200f]" /> {g.languages.join(", ")}</span>
              </div>
              <p class="mt-3 text-sm leading-relaxed text-[color:var(--color-charcoal-soft)]">{g.bio}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Conservation ethos -->
  <section class="relative overflow-hidden">
    <img src="/images/destinations/ol-pejeta.webp" alt="Rhino grazing on the Ol Pejeta conservancy at dusk" loading="lazy" decoding="async" class="absolute inset-0 size-full object-cover" />
    <div class="absolute inset-0 bg-[#faf5ec]/80"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-[#faf5ec] via-[#faf5ec]/70 to-transparent"></div>
    <div class="relative mx-auto max-w-[1400px] px-5 py-20 lg:px-10 lg:py-28">
      <div class="max-w-2xl" data-reveal>
        <p class="eyebrow text-[#96690f]">Conservation ethos</p>
        <h2 class="display-2 mt-4 text-[color:var(--color-charcoal)]">The wild pays for itself, or it disappears.</h2>
        <p class="mt-5 max-w-xl text-lg leading-relaxed text-[color:var(--color-charcoal-soft)]">
          Kenya's wildlife lives largely outside fenced parks, on land people could otherwise farm. Conservancies flip that maths — tourism makes a living lion worth more than a dead one. We channel trips and a share of every booking into that model, and we'll happily show you exactly where it goes.
        </p>
        <a href="/contact" class="mt-8 inline-flex items-center gap-2 rounded-full bg-[#3f200f] px-6 py-3.5 text-sm font-bold text-white transition-colors hover:bg-[#5c3b26]">
          Plan a conservancy safari
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
