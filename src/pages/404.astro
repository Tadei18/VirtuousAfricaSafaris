---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteUrl } from "@/lib/constants";
import { Home, Compass, ArrowRight } from "lucide-react";

const seo = {
  title: "Page not found",
  description: "The page you're looking for has wandered off the trail.",
  canonical: `${siteUrl}/404`,
};
---

<BaseLayout seo={seo} transparentHeader>
  <section class="relative isolate flex min-h-[100svh] items-center overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <img src="/images/visual-essay/lion-mara-dawn.webp" alt="" class="size-full object-cover opacity-40" />
      <div class="absolute inset-0 bg-gradient-to-t from-[#2a1509] via-[#2a1509]/85 to-[#2a1509]/70"></div>
    </div>
    <div class="mx-auto max-w-2xl px-5 text-center">
      <p class="font-display text-[7rem] font-extrabold leading-none text-ember-gradient sm:text-[10rem]">404</p>
      <h1 class="display-3 mt-2 text-[color:var(--color-bone)]">This trail leads nowhere.</h1>
      <p class="mx-auto mt-4 max-w-md text-lg text-[color:var(--color-fog)]">
        The page you were tracking has moved on. Let's get you back to the herd.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a href="/" class="inline-flex items-center gap-2 rounded-full bg-[#cfa24a] px-6 py-3.5 text-sm font-bold text-[#2a1509] transition-colors hover:bg-[#e8cf94]">
          <Home className="size-4" /> Back home
        </a>
        <a href="/safaris" class="inline-flex items-center gap-2 rounded-full border border-[color:var(--color-line-strong)] px-6 py-3.5 text-sm font-bold text-[color:var(--color-bone)] transition-colors hover:border-[#cfa24a]">
          <Compass className="size-4" /> Browse safaris <ArrowRight className="size-4" />
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
