---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/ui/PageHeader.astro";
import StarRating from "@/components/ui/StarRating.astro";
import { testimonials } from "@/data/testimonials";
import { reviewsSeo } from "@/data/seo";
import { Quote, Star } from "lucide-react";

const avg =
  testimonials.reduce((s, t) => s + t.rating, 0) / testimonials.length;
---

<BaseLayout seo={reviewsSeo}>
  <PageHeader
    eyebrow="Reviews"
    title="The trips people can't stop describing."
    intro="We'd rather let travellers tell it. Here's what a river crossing, a first leopard, or ten days done right actually feels like."
  >
    <div class="mt-8 inline-flex items-center gap-4 rounded-2xl border border-[color:var(--color-line)] bg-[#12151b] px-6 py-4" data-reveal style="--reveal-delay:200ms">
      <p class="font-display text-4xl font-extrabold text-[#ffb056]">{avg.toFixed(1)}</p>
      <div>
        <StarRating rating={avg} size="size-4" />
        <p class="mt-1 text-sm text-[color:var(--color-fog)]">from {testimonials.length}+ verified travellers</p>
      </div>
    </div>
  </PageHeader>

  <section class="bg-[#0c0e12] py-16 lg:py-20">
    <div class="mx-auto max-w-[1400px] px-5 lg:px-10">
      <div class="columns-1 gap-5 sm:columns-2 lg:columns-3 [&>*]:mb-5 [&>*]:break-inside-avoid">
        {
          testimonials.map((t, i) => (
            <figure class="flex flex-col rounded-[1.5rem] border border-[color:var(--color-line)] bg-[#12151b] p-7 transition-colors hover:border-[#ff6a1a]/30" data-reveal style={`--reveal-delay:${(i % 3) * 70}ms`}>
              <Quote className="size-8 text-[#ff6a1a]/40" />
              <blockquote class="mt-4 text-[15px] leading-relaxed text-[color:var(--color-bone)]/90">"{t.quote}"</blockquote>
              <figcaption class="mt-6 border-t border-[color:var(--color-line)] pt-5">
                <StarRating rating={t.rating} size="size-3.5" />
                <p class="mt-2 font-display text-base font-bold text-[color:var(--color-bone)]">{t.name}</p>
                <p class="text-sm text-[color:var(--color-fog)]">{t.country}</p>
                <a href={`/safaris/${t.tourSlug}`} class="mt-2 inline-block text-xs font-semibold text-[#ffb056] hover:underline">{t.tourTitle} →</a>
              </figcaption>
            </figure>
          ))
        }
      </div>

      <div class="mt-14 rounded-[1.75rem] border border-[color:var(--color-line)] bg-gradient-to-br from-[#1a1e26] to-[#0c0e12] p-8 text-center md:p-12" data-reveal>
        <Star className="mx-auto size-8 text-[#ffb056]" />
        <h2 class="display-3 mt-4 text-[color:var(--color-bone)]">Your review could be next.</h2>
        <p class="mx-auto mt-3 max-w-md text-[color:var(--color-fog)]">Start with a no-obligation plan. If it's the trip of a lifetime, tell the world after.</p>
        <a href="/contact" class="mt-6 inline-flex rounded-full bg-[#ff6a1a] px-6 py-3.5 text-sm font-bold text-white transition-colors hover:bg-[#ff8a3d]">Plan your safari</a>
      </div>
    </div>
  </section>
</BaseLayout>
