---
import { ArrowUpRight, Maximize } from "lucide-react";
import type { Destination } from "@/types";

interface Props {
  destination: Destination;
  eager?: boolean;
}
const { destination: d, eager = false } = Astro.props;
---

<a
  href={`/destinations/${d.slug}`}
  class="group relative flex min-h-[22rem] flex-col justify-end overflow-hidden rounded-[1.5rem] border border-[color:var(--color-line)] p-6 transition-all duration-500 hover:-translate-y-1.5 hover:border-[#ff6a1a]/40 hover:shadow-[0_28px_70px_rgba(0,0,0,0.5)]"
>
  <img
    src={d.heroImage}
    alt={d.name}
    width="800"
    height="1000"
    loading={eager ? "eager" : "lazy"}
    decoding="async"
    class="absolute inset-0 size-full object-cover transition-transform duration-[900ms] ease-out group-hover:scale-110"
  />
  <div class="absolute inset-0 bg-gradient-to-t from-[#0c0e12] via-[#0c0e12]/40 to-[#0c0e12]/5"></div>

  <div class="relative">
    <span class="inline-flex items-center gap-1.5 rounded-full border border-white/20 bg-black/30 px-3 py-1 text-[11px] font-semibold text-white backdrop-blur">
      {d.sizeKm2 > 0 ? `${d.sizeKm2.toLocaleString()} km²` : "Indian Ocean coast"}
    </span>
    <h3 class="mt-3 font-display text-2xl font-extrabold text-white">{d.name}</h3>
    <p class="mt-1 text-sm font-medium text-[#ffb056]">{d.oneLineDraw}</p>
    <div class="mt-4 flex flex-wrap gap-1.5">
      {d.signatureWildlife.slice(0, 3).map((w) => (
        <span class="rounded-full bg-white/10 px-2.5 py-1 text-[11px] font-medium text-white/90 backdrop-blur">{w}</span>
      ))}
    </div>
  </div>

  <span class="absolute right-5 top-5 inline-flex size-10 items-center justify-center rounded-full bg-white/10 text-white backdrop-blur transition-all group-hover:bg-[#ff6a1a]">
    <ArrowUpRight className="size-5" />
  </span>
</a>
