---
import MobileNav from "@/components/react/MobileNav.tsx";
import Logo from "@/components/ui/Logo.astro";
import { navLinks } from "@/lib/constants";

interface Props {
  transparent?: boolean;
}
const { transparent = false } = Astro.props;
const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<header
  id="site-header"
  data-transparent={transparent ? "true" : "false"}
  class:list={[
    "fixed inset-x-0 top-0 z-[90] transition-all duration-300",
    transparent
      ? "bg-transparent"
      : "bg-[#2a1509]/95 backdrop-blur border-b border-[color:var(--color-line)]",
  ]}
>
  <div class="mx-auto flex max-w-[1400px] items-center justify-between px-5 py-3.5 lg:px-10">
    <a href="/" class="group flex items-center" aria-label="Virtuous Africa Safaris home">
      <Logo light class="h-9 w-auto transition-transform group-hover:scale-[1.03] sm:h-10" />
    </a>

    <nav class="hidden items-center gap-1 lg:flex" aria-label="Primary">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            aria-current={isActive(link.href) ? "page" : undefined}
            class:list={[
              "rounded-full px-4 py-2 text-sm font-semibold transition-colors",
              isActive(link.href)
                ? "text-[#cfa24a]"
                : "text-[color:var(--color-fog)] hover:text-[color:var(--color-bone)]",
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="/contact"
        class="hidden rounded-full bg-[#cfa24a] px-5 py-2.5 text-sm font-bold text-[#2a1509] transition-all hover:bg-[#e8cf94] hover:shadow-[0_10px_30px_rgba(207,162,74,0.35)] sm:inline-flex"
      >
        Plan your safari
      </a>
      <MobileNav client:idle />
    </div>
  </div>
</header>

<!-- Spacer for non-transparent header so content isn't hidden underneath. -->
{!transparent && <div class="h-[68px]" aria-hidden="true"></div>}

<script is:inline>
  (() => {
    const header = document.getElementById("site-header");
    if (!header || header.dataset.transparent !== "true") return;
    const solid = [
      "bg-[#2a1509]/95",
      "backdrop-blur",
      "border-b",
      "border-[color:var(--color-line)]",
    ];
    const onScroll = () => {
      if (window.scrollY > 40) header.classList.add(...solid);
      else header.classList.remove(...solid);
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  })();
</script>
