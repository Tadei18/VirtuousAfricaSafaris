---
import MobileNav from "@/components/react/MobileNav.tsx";
import { navLinks } from "@/lib/constants";

interface Props {
  transparent?: boolean;
}
const { transparent = false } = Astro.props;
const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<header
  id="site-header"
  data-transparent={transparent ? "true" : "false"}
  class:list={[
    "fixed inset-x-0 top-0 z-[90] transition-all duration-300",
    transparent ? "bg-transparent" : "bg-[#0c0e12]/85 backdrop-blur border-b border-[color:var(--color-line)]",
  ]}
>
  <div class="mx-auto flex max-w-[1400px] items-center justify-between px-5 py-4 lg:px-10">
    <!-- Wordmark placeholder. TODO: replace with client logo. -->
    <a href="/" class="group flex items-center gap-2.5" aria-label="Virtuous Africa Safaris home">
      <span
        class="inline-flex size-9 items-center justify-center rounded-xl bg-[#ff6a1a] font-display text-lg font-extrabold text-white shadow-[0_8px_24px_rgba(255,106,26,0.35)] transition-transform group-hover:-rotate-6"
        aria-hidden="true">V</span
      >
      <span class="font-display text-[1.35rem] font-extrabold leading-none tracking-tight text-[color:var(--color-bone)]">
        Virtuous<span class="text-[#ff6a1a]">Africa</span>
      </span>
    </a>

    <nav class="hidden items-center gap-1 lg:flex" aria-label="Primary">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            aria-current={isActive(link.href) ? "page" : undefined}
            class:list={[
              "rounded-full px-4 py-2 text-sm font-semibold transition-colors",
              isActive(link.href)
                ? "text-[#ff6a1a]"
                : "text-[color:var(--color-fog)] hover:text-[color:var(--color-bone)]",
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="/contact"
        class="hidden rounded-full bg-[#ff6a1a] px-5 py-2.5 text-sm font-bold text-white transition-all hover:bg-[#ff8a3d] hover:shadow-[0_10px_30px_rgba(255,106,26,0.35)] sm:inline-flex"
      >
        Plan your safari
      </a>
      <MobileNav client:idle />
    </div>
  </div>
</header>

<!-- Spacer for non-transparent header so content isn't hidden underneath. -->
{!transparent && <div class="h-[72px]" aria-hidden="true"></div>}

<script is:inline>
  (() => {
    const header = document.getElementById("site-header");
    if (!header || header.dataset.transparent !== "true") return;
    const solid = [
      "bg-[#0c0e12]/85",
      "backdrop-blur",
      "border-b",
      "border-[color:var(--color-line)]",
    ];
    const onScroll = () => {
      if (window.scrollY > 40) header.classList.add(...solid);
      else header.classList.remove(...solid);
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  })();
</script>
