---
import NewsletterForm from "@/components/react/NewsletterForm.tsx";
import Logo from "@/components/ui/Logo.astro";
import {
  siteName,
  siteTagline,
  navLinks,
  contact,
  social,
  trustBadges,
  whatsappUrl,
} from "@/lib/constants";
import { Instagram, Facebook, Youtube, Mail, Phone, MapPin } from "lucide-react";

const year = new Date().getFullYear();
const destinationLinks = [
  { href: "/destinations/maasai-mara", label: "Maasai Mara" },
  { href: "/destinations/amboseli", label: "Amboseli" },
  { href: "/destinations/samburu", label: "Samburu" },
  { href: "/destinations/tsavo", label: "Tsavo" },
  { href: "/destinations/diani-beach", label: "Diani Beach" },
];
---

<footer class="relative overflow-hidden bg-[#2a1509] text-[color:var(--color-fog)]">
  <!-- Newsletter band -->
  <div class="border-b border-[color:var(--color-line)]">
    <div class="mx-auto grid max-w-[1400px] gap-8 px-5 py-14 lg:grid-cols-2 lg:px-10">
      <div>
        <p class="eyebrow text-[#cfa24a]">Field notes</p>
        <h2 class="display-3 mt-3 text-[color:var(--color-bone)]">
          Dispatches from the bush.
        </h2>
        <p class="mt-3 max-w-md text-[color:var(--color-fog)]">
          Best months, migration timing, and quiet-season deals — a few times a
          year, never spam.
        </p>
      </div>
      <div class="flex flex-col justify-center">
        <NewsletterForm client:visible />
        <p class="mt-3 text-xs text-[color:var(--color-fog-2)]">
          By subscribing you agree to receive occasional emails. Unsubscribe any
          time.
        </p>
      </div>
    </div>
  </div>

  <!-- Main footer -->
  <div class="mx-auto max-w-[1400px] px-5 py-14 lg:px-10">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center" aria-label={`${siteName} home`}>
          <Logo light class="h-11 w-auto" />
        </a>
        <p class="mt-5 max-w-xs text-sm text-[color:var(--color-fog)]">
          {siteTagline} Private, guide-led Kenyan safaris built around the
          wildlife you came for.
        </p>
        <div class="mt-5 flex gap-2">
          <a href={social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="inline-flex size-10 items-center justify-center rounded-full border border-[color:var(--color-line-strong)] text-[color:var(--color-fog)] transition-colors hover:border-[#cfa24a] hover:text-[#cfa24a]">
            <Instagram className="size-4" />
          </a>
          <a href={social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="inline-flex size-10 items-center justify-center rounded-full border border-[color:var(--color-line-strong)] text-[color:var(--color-fog)] transition-colors hover:border-[#cfa24a] hover:text-[#cfa24a]">
            <Facebook className="size-4" />
          </a>
          <a href={social.youtube} target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="inline-flex size-10 items-center justify-center rounded-full border border-[color:var(--color-line-strong)] text-[color:var(--color-fog)] transition-colors hover:border-[#cfa24a] hover:text-[#cfa24a]">
            <Youtube className="size-4" />
          </a>
        </div>
      </div>

      <nav aria-label="Explore" class="text-sm">
        <h3 class="font-display text-base font-bold text-[color:var(--color-bone)]">Explore</h3>
        <ul class="mt-4 space-y-2.5">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="text-[color:var(--color-fog)] transition-colors hover:text-[#cfa24a]">{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <nav aria-label="Destinations" class="text-sm">
        <h3 class="font-display text-base font-bold text-[color:var(--color-bone)]">Destinations</h3>
        <ul class="mt-4 space-y-2.5">
          {destinationLinks.map((link) => (
            <li>
              <a href={link.href} class="text-[color:var(--color-fog)] transition-colors hover:text-[#cfa24a]">{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="text-sm">
        <h3 class="font-display text-base font-bold text-[color:var(--color-bone)]">Get in touch</h3>
        <ul class="mt-4 space-y-3 text-[color:var(--color-fog)]">
          <li class="flex items-start gap-2.5">
            <Phone className="mt-0.5 size-4 shrink-0 text-[#cfa24a]" />
            <a href={`tel:${contact.phoneTel}`} class="transition-colors hover:text-[color:var(--color-bone)]">{contact.phoneDisplay}</a>
          </li>
          <li class="flex items-start gap-2.5">
            <Mail className="mt-0.5 size-4 shrink-0 text-[#cfa24a]" />
            <a href={`mailto:${contact.email}`} class="transition-colors hover:text-[color:var(--color-bone)]">{contact.email}</a>
          </li>
          <li class="flex items-start gap-2.5">
            <MapPin className="mt-0.5 size-4 shrink-0 text-[#cfa24a]" />
            <span>{contact.address}</span>
          </li>
        </ul>
        <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="mt-4 inline-flex rounded-full border border-[color:var(--color-line-strong)] px-4 py-2 text-xs font-semibold text-[color:var(--color-bone)] transition-colors hover:border-[#cfa24a] hover:text-[#cfa24a]">
          Chat on WhatsApp
        </a>
      </div>
    </div>

    <!-- Trust badges (structural placeholders — client to confirm) -->
    <div class="mt-12 flex flex-wrap items-center gap-3 border-t border-[color:var(--color-line)] pt-8">
      {trustBadges.map((badge) => (
        <span class="inline-flex items-center gap-1.5 rounded-full border border-[color:var(--color-line-strong)] px-3.5 py-1.5 text-[11px] font-semibold uppercase tracking-wider text-[color:var(--color-fog)]">
          <span class="size-1.5 rounded-full bg-[#cfa24a]" aria-hidden="true"></span>
          {badge}
        </span>
      ))}
    </div>

    <div class="mt-8 flex flex-col gap-2 text-xs text-[color:var(--color-fog-2)] sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} {siteName}. All rights reserved.</p>
      <p>Placeholder contact details — verify before launch. Built with Astro.</p>
    </div>
  </div>
</footer>
