---
import type { RouteStop } from "@/types";

interface Props {
  stops: RouteStop[];
}
const { stops } = Astro.props;

// Rough, illustrative outline of Kenya, hand-tuned to the 0–100 viewbox so the
// destination coords in tours.ts align visually (not cartographically precise).
const KENYA_OUTLINE =
  "M22 30 L34 18 L48 12 L60 15 L72 22 L80 32 L84 42 L82 56 L88 68 L92 80 L85 90 L70 92 L55 94 L42 92 L30 85 L18 72 L14 58 L18 44 Z";

const path = stops
  .map((s, i) => `${i === 0 ? "M" : "L"} ${s.x} ${s.y}`)
  .join(" ");
---

<div class="rounded-[1.5rem] border border-[color:var(--color-line-ink)] bg-[#fffdf9] p-6">
  <svg
    viewBox="0 0 100 100"
    class="mx-auto w-full max-w-sm"
    aria-labelledby="route-map-title"
    role="img"
  >
    <title id="route-map-title">Route map of the journey across Kenya</title>
    <defs>
      <linearGradient id="routeGrad" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="#96690f" />
        <stop offset="1" stop-color="#3f200f" />
      </linearGradient>
    </defs>
    <path
      d={KENYA_OUTLINE}
      fill="#efe3d0"
      stroke="rgba(63,32,15,0.2)"
      stroke-width="0.5"
    />
    <path
      d={path}
      fill="none"
      stroke="url(#routeGrad)"
      stroke-width="0.9"
      stroke-dasharray="2 1.6"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
    {
      stops.map((s, i) => (
        <g>
          <circle cx={s.x} cy={s.y} r="1.8" fill="#3f200f" stroke="#faf5ec" stroke-width="0.5" />
          <text
            x={s.x + 2.6}
            y={s.y + 1}
            font-size="3.1"
            font-family="Manrope, sans-serif"
            font-weight="700"
            fill="#2e1b10"
          >
            {s.label}
          </text>
        </g>
      ))
    }
  </svg>
  <p class="mt-4 text-center text-sm text-[color:var(--color-charcoal-soft)]">
    {
      stops.map((s, i) => (
        <span>
          {i > 0 && <span class="text-[color:var(--color-charcoal-soft)]"> → </span>}
          <span class="font-semibold text-[color:var(--color-charcoal)]">{s.label}</span>
        </span>
      ))
    }
  </p>
</div>
