---
const tiles = [
  {
    src: "/images/visual-essay/lion-mara-dawn.webp",
    alt: "Lion in golden first light, Mara Triangle",
    caption: "Lion at first light — Mara Triangle",
    className: "sm:col-span-3 sm:row-span-2",
  },
  {
    src: "/images/visual-essay/elephants-kilimanjaro.webp",
    alt: "Elephant herd silhouetted against Mount Kilimanjaro at sunrise",
    caption: "Elephants under Kilimanjaro — Amboseli",
    className: "sm:col-span-3",
  },
  {
    src: "/images/visual-essay/reticulated-giraffe-samburu.webp",
    alt: "Reticulated giraffe close-up in northern Kenya scrub",
    caption: "Reticulated giraffe — Samburu",
    className: "sm:col-span-2 sm:row-span-2",
  },
  {
    src: "/images/visual-essay/wild-dogs-laikipia.webp",
    alt: "Wild dog pack on the move in Laikipia scrubland",
    caption: "Wild dogs — Laikipia",
    className: "sm:col-span-1",
  },
  {
    src: "/images/visual-essay/flamingos-bogoria.webp",
    alt: "Pink flamingo flock on a Rift Valley lake at dawn",
    caption: "Flamingos — Lake Bogoria",
    className: "sm:col-span-3",
  },
];
---

<section class="bg-[#faf5ec] py-20 lg:py-28">
  <div class="mx-auto max-w-[1400px] px-5 lg:px-10">
    <header class="max-w-2xl" data-reveal>
      <p class="eyebrow text-[#96690f]">The field</p>
      <h2 class="display-2 mt-4 text-[color:var(--color-charcoal)]">
        Moments we tend to deliver.
      </h2>
      <p class="mt-4 text-lg text-[color:var(--color-charcoal-soft)]">
        Not stock promises — the kind of light and proximity our guides put you
        in, week after week.
      </p>
    </header>

    <div
      class="mt-12 grid auto-rows-[220px] grid-cols-2 gap-3 sm:grid-cols-6 md:auto-rows-[260px] md:gap-4"
      data-reveal
    >
      {
        tiles.map((tile, i) => (
          <figure
            class:list={[
              "group relative overflow-hidden rounded-2xl border border-[color:var(--color-line-ink)] bg-[#fffdf9]",
              tile.className,
            ]}
          >
            <img
              src={tile.src}
              alt={tile.alt}
              loading="lazy"
              decoding="async"
              class="size-full object-cover transition-transform duration-[900ms] ease-out group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[#2a1509]/90 via-transparent to-transparent"></div>
            <figcaption class="absolute inset-x-0 bottom-0 p-4 text-[11px] font-semibold uppercase tracking-[0.14em] text-white opacity-0 transition-opacity duration-300 group-hover:opacity-100">
              {tile.caption}
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
