---
import { heroTrust } from "@/lib/constants";
import { ArrowRight, Play, Star } from "lucide-react";
---

<section class="relative isolate flex min-h-[100svh] flex-col justify-end overflow-hidden">
  <!-- Ken-Burns background -->
  <div class="absolute inset-0 -z-10">
    <img
      src="/images/hero-home.jpeg"
      alt="Family on a safari game drive watching elephants at a waterhole at sunset"
      width="1600"
      height="1067"
      fetchpriority="high"
      loading="eager"
      decoding="async"
      class="ken-burns size-full object-cover object-[62%_center] sm:object-center"
    />
    <!-- Text-side scrim: strong deep espresso on the left/bottom (where the copy
         sits) so cream text stays AA-legible over the brighter new photo, while
         the right side (elephants, sky) keeps its light. -->
    <div class="absolute inset-0 bg-gradient-to-t from-[#2a1509] via-[#2a1509]/60 to-[#2a1509]/40"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-[#2a1509]/88 via-[#2a1509]/25 to-transparent"></div>
  </div>

  <div class="mx-auto w-full max-w-[1400px] px-5 pb-16 pt-32 lg:px-10 lg:pb-24">
    <p class="eyebrow text-[#cfa24a]" data-reveal>Kenya · Est. wild</p>

    <h1 class="display-1 mt-5 max-w-4xl text-[color:var(--color-bone)]" data-reveal style="--reveal-delay:80ms">
      Your African <span class="text-ember-gradient">Adventure</span> Starts Here
    </h1>

    <p class="mt-6 max-w-xl text-lg leading-relaxed text-[color:var(--color-fog)] md:text-xl" data-reveal style="--reveal-delay:160ms">
      Experience the beauty of Africa through expertly curated safaris, luxury
      escapes, and authentic travel experiences designed to create memories that
      last a lifetime.
    </p>

    <div class="mt-9 flex flex-wrap items-center gap-4" data-reveal style="--reveal-delay:240ms">
      <a
        href="/destinations"
        class="group inline-flex items-center gap-2.5 rounded-full bg-[#cfa24a] px-7 py-4 text-base font-bold text-[#2a1509] transition-all hover:bg-[#e8cf94] hover:shadow-[0_16px_44px_rgba(207,162,74,0.45)]"
      >
        Explore Destinations
        <ArrowRight className="size-5 transition-transform group-hover:translate-x-1" />
      </a>
      <a
        href="/contact"
        class="inline-flex items-center gap-2.5 rounded-full border border-[color:var(--color-line-strong)] bg-white/5 px-7 py-4 text-base font-bold text-[color:var(--color-bone)] backdrop-blur transition-colors hover:border-[#cfa24a]"
      >
        <Play className="size-4 fill-current" /> Plan Your Journey
      </a>
    </div>

    <!-- Trust row -->
    <ul class="mt-12 flex flex-wrap items-center gap-x-7 gap-y-3" data-reveal style="--reveal-delay:320ms">
      {
        heroTrust.map((item) => (
          <li class="inline-flex items-center gap-2 text-sm font-semibold text-[color:var(--color-fog)]">
            <Star className="size-4 fill-[#cfa24a] text-[#cfa24a]" />
            {item}
          </li>
        ))
      }
    </ul>
  </div>

  <!-- Scroll cue -->
  <div class="pointer-events-none absolute bottom-6 left-1/2 hidden -translate-x-1/2 lg:block">
    <div class="flex h-11 w-6 items-start justify-center rounded-full border-2 border-white/30 p-1.5">
      <span class="block h-2 w-1 animate-bounce rounded-full bg-white/70"></span>
    </div>
  </div>
</section>
