---
// Quick-match helper — a zero-JS progressive form. Submitting navigates to
// /safaris with query params the filter island reads and pre-applies.
import { Wand2, ArrowRight } from "lucide-react";

const whenOptions = [
  { value: "", label: "Any time" },
  { value: "jan-mar", label: "Jan – Mar" },
  { value: "apr-jun", label: "Apr – Jun" },
  { value: "jul-sep", label: "Jul – Sep" },
  { value: "oct-dec", label: "Oct – Dec" },
];
const daysOptions = [
  { value: "", label: "Any length" },
  { value: "3-5", label: "3 – 5 days" },
  { value: "6-8", label: "6 – 8 days" },
  { value: "9-12", label: "9 – 12 days" },
  { value: "13+", label: "13+ days" },
];
const styleOptions = [
  { value: "", label: "Any style" },
  { value: "Budget", label: "Budget" },
  { value: "Mid-range", label: "Mid-range" },
  { value: "Luxury", label: "Luxury" },
  { value: "Family", label: "Family" },
];

const fields = [
  { name: "when", label: "When are you travelling?", options: whenOptions },
  { name: "days", label: "How many days?", options: daysOptions },
  { name: "style", label: "What style?", options: styleOptions },
];
---

<section class="relative overflow-hidden bg-[#0c0e12] pb-20 lg:pb-28">
  <div class="mx-auto max-w-[1400px] px-5 lg:px-10">
    <div
      class="noise relative overflow-hidden rounded-[1.75rem] border border-[#ff6a1a]/25 bg-gradient-to-br from-[#1a1e26] via-[#12151b] to-[#0c0e12] p-8 md:p-12"
      data-reveal
    >
      <div class="absolute -right-16 -top-16 size-64 rounded-full bg-[#ff6a1a]/15 blur-3xl"></div>
      <div class="relative grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">
        <div>
          <p class="eyebrow text-[#ffb056]"><Wand2 className="size-4" /> Quick match</p>
          <h2 class="display-3 mt-4 text-[color:var(--color-bone)]">
            Tell us three things.
          </h2>
          <p class="mt-3 max-w-sm text-[color:var(--color-fog)]">
            We'll narrow the shortlist in one click. The proper planning
            conversation comes after.
          </p>
        </div>

        <form action="/safaris" method="get" class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          {
            fields.map((f) => (
              <label class="flex flex-col gap-1.5">
                <span class="text-xs font-semibold text-[color:var(--color-fog)]">{f.label}</span>
                <select
                  name={f.name}
                  class="h-12 rounded-xl border border-[color:var(--color-line-strong)] bg-[#0c0e12] px-3 text-sm font-medium text-[color:var(--color-bone)] focus:border-[#ff6a1a] focus:outline-none"
                >
                  {f.options.map((o) => (
                    <option value={o.value}>{o.label}</option>
                  ))}
                </select>
              </label>
            ))
          }
          <div class="flex items-end sm:col-span-2 lg:col-span-1">
            <button
              type="submit"
              class="inline-flex h-12 w-full items-center justify-center gap-2 rounded-xl bg-[#ff6a1a] px-5 text-sm font-bold text-white transition-colors hover:bg-[#ff8a3d]"
            >
              Match <ArrowRight class="size-4" />
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
