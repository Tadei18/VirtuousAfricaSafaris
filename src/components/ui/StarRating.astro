---
interface Props {
  rating: number;
  count?: number;
  /** Tailwind size class for each star, e.g. "size-4". */
  size?: string;
  class?: string;
}
const { rating, count, size = "size-4", class: cls = "" } = Astro.props;
const pct = Math.max(0, Math.min(100, (rating / 5) * 100));
---

<div class:list={["inline-flex items-center gap-2", cls]}>
  <div
    class="relative inline-flex"
    role="img"
    aria-label={`Rated ${rating} out of 5`}
  >
    <!-- track -->
    <div class="inline-flex text-[color:var(--color-fog-2)]/40">
      {
        Array.from({ length: 5 }).map(() => (
          <svg class={size} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2l2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01L12 2z" />
          </svg>
        ))
      }
    </div>
    <!-- fill -->
    <div
      class="absolute inset-0 inline-flex overflow-hidden text-[#e8b04b]"
      style={`width:${pct}%`}
    >
      {
        Array.from({ length: 5 }).map(() => (
          <svg class={size + " shrink-0"} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2l2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01L12 2z" />
          </svg>
        ))
      }
    </div>
  </div>
  <span class="text-sm font-semibold text-[color:var(--color-bone)]">{rating.toFixed(1)}</span>
  {count !== undefined && (
    <span class="text-sm text-[color:var(--color-fog)]">({count})</span>
  )}
</div>
