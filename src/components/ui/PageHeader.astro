---
interface Props {
  eyebrow: string;
  title: string;
  intro?: string;
  image?: string;
  imageAlt?: string;
  align?: "left" | "center";
}
const {
  eyebrow,
  title,
  intro,
  image,
  imageAlt = "",
  align = "left",
} = Astro.props;

// Image headers render as a dark-brown band (photo + overlay + cream text);
// plain headers render light (ivory + brown/charcoal text).
const dark = !!image;
---

<section
  class:list={[
    "relative isolate overflow-hidden border-b",
    dark
      ? "border-[color:var(--color-line)] bg-[#2a1509]"
      : "border-[color:var(--color-line-ink)] bg-[#faf5ec]",
  ]}
>
  {
    image && (
      <div class="absolute inset-0 -z-10">
        <img
          src={image}
          alt={imageAlt}
          fetchpriority="high"
          class="size-full object-cover opacity-70"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-[#2a1509] via-[#2a1509]/75 to-[#2a1509]/55" />
      </div>
    )
  }
  <div
    class:list={[
      "mx-auto max-w-[1400px] px-5 lg:px-10",
      image ? "pt-28 pb-16 lg:pt-36 lg:pb-20" : "pt-16 pb-12 lg:pt-20 lg:pb-16",
      align === "center" && "text-center",
    ]}
  >
    <p
      class:list={[
        "eyebrow",
        dark ? "text-[#cfa24a]" : "text-[#96690f]",
        align === "center" && "justify-center",
      ]}
      data-reveal
    >
      {eyebrow}
    </p>
    <h1
      class:list={[
        "display-2 mt-4",
        dark ? "text-[color:var(--color-bone)]" : "text-[color:var(--color-charcoal)]",
        align === "center" ? "mx-auto max-w-3xl" : "max-w-3xl",
      ]}
      data-reveal
      style="--reveal-delay:80ms"
    >
      {title}
    </h1>
    {
      intro && (
        <p
          class:list={[
            "mt-5 text-lg leading-relaxed",
            dark ? "text-[color:var(--color-fog)]" : "text-[color:var(--color-charcoal-soft)]",
            align === "center" ? "mx-auto max-w-2xl" : "max-w-2xl",
          ]}
          data-reveal
          style="--reveal-delay:140ms"
        >
          {intro}
        </p>
      )
    }
    <slot />
  </div>
</section>
